{
  "version": 6,
  "entities": [
    {
      "entity": {
        "type": "Project",
        "id": "b6565e46-4d19-4e35-bb23-e592d0826793",
        "name": "AuthFoundation - PasswordAccountFlow"
      },
      "children": [
        {
          "entity": {
            "type": "Scenario",
            "id": "77ad7a86-56ff-4ae0-8d88-5d45b435dc0c",
            "name": "PasswordAccountFlow"
          },
          "children": [
            {
              "entity": {
                "type": "Request",
                "id": "1778ec9d-544b-433a-85bc-991e666d4f8a",
                "name": "01. Reset forgotten password",
                "method": { "name": "POST", "requestBody": true },
                "uri": {
                  "scheme": { "secure": true, "name": "https", "version": "V11" },
                  "host": "${\"AuthHost\"}",
                  "path": "/password/reset"
                },
                "headers": [
                  { "enabled": true, "name": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "bodyType": "Text",
                  "textBody": "{ \"email\": \"${\"Email\"}\", \"birth_date\": \"${\"BirthDate\"}\", \"new_password\": \"${\"NewPassword\"}\" }"
                }
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "6e673ed1-dd3d-4344-9a22-a02381dd830d",
                "name": "02. Change password with step-up",
                "method": { "name": "POST", "requestBody": true },
                "uri": {
                  "scheme": { "secure": true, "name": "https", "version": "V11" },
                  "host": "${\"AuthHost\"}",
                  "path": "/account/password"
                },
                "headers": [
                  { "enabled": true, "name": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "bodyType": "Text",
                  "textBody": "{ \"email\": \"${\"Email\"}\", \"current_password\": \"${\"Password\"}\", \"new_password\": \"${\"NewPassword\"}\", \"step_up_token\": \"${\"StepUpToken\"}\" }"
                }
              }
            },
            {
              "entity": {
                "type": "Request",
                "id": "e82c954a-d43d-4cf8-9532-522f1aa1419d",
                "name": "03. Withdraw account with step-up",
                "method": { "name": "POST", "requestBody": true },
                "uri": {
                  "scheme": { "secure": true, "name": "https", "version": "V11" },
                  "host": "${\"AuthHost\"}",
                  "path": "/account/withdrawal"
                },
                "headers": [
                  { "enabled": true, "name": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "bodyType": "Text",
                  "textBody": "{ \"email\": \"${\"Email\"}\", \"password\": \"${\"Password\"}\", \"step_up_token\": \"${\"StepUpToken\"}\" }"
                }
              }
            }
          ]
        }
      ]
    }
  ],
  "environments": [
    {
      "id": "c3a613b3-d262-4907-8cb8-9b5faefcbd4b",
      "name": "production",
      "variables": {
        "auth-host": { "name": "AuthHost", "value": "auth.osolab-auth.jp", "enabled": true, "private": false },
        "email": { "name": "Email", "value": null, "enabled": true, "private": true },
        "password": { "name": "Password", "value": null, "enabled": true, "private": true },
        "new-password": { "name": "NewPassword", "value": null, "enabled": true, "private": true },
        "birth-date": { "name": "BirthDate", "value": null, "enabled": true, "private": true },
        "step-up-token": { "name": "StepUpToken", "value": null, "enabled": true, "private": true }
      }
    }
  ]
}
